namespace isotime.storage;

enum CompressionType : byte { None = 0, DeltaDelta = 1 }

table RawValue {
  data: [ubyte];
  compression: CompressionType = None;
}

table RefValue {
  offset: uint32;
}

union ValueType { RawValue, RefValue }

table Entry {
  key: [ubyte];
  value: ValueType;
}

table SSTableData {
  entries: [Entry];
  bloom_filter: [ubyte];
  num_hashes: uint32;
}

root_type SSTableData;
